# ROCm stack for MI355X — single source of truth (sourced by setup scripts).
#
# AMD latest stable: ROCm 7.2.3 (May 2026) — https://github.com/ROCm/ROCm/releases/latest
# Host module load on compute nodes; container uses vLLM OpenAI ROCm nightly image.
#
# Host module (Environment Modules on compute nodes):
export ROCM_VERSION="7.2.3"
export ROCM_MODULE="rocm/${ROCM_VERSION}"

# Default dev container (vLLM OpenAI ROCm — latest nightly on docker.io)
export CONTAINER_NAME="vllm-dev"
export PORT_MAP="8080:8000"
export VLLM_IMAGE="docker.io/vllm/vllm-openai-rocm:nightly"

# Local scratch on compute nodes (optional mount):
export DATA_MOUNT="/data"
# Shared NFS model store — survives across nodes/jobs; avoids re-downloading weights:
export HF_HOME="/shared/data/amd_int/models"
export HF_HOME_MOUNT="${HF_HOME}"
# Shared NFS home — bind-mount into container so edits survive container removal:
export HOME_DIR="/shared/amdgpu/home/fai_qle"
export HOME_MOUNT="${HOME_DIR}"
