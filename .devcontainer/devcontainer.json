{
  "name": "vllm-dev (vLLM OpenAI ROCm)",
  "image": "docker.io/vllm/vllm-openai-rocm:nightly",
  "remoteUser": "root",
  "workspaceFolder": "/shared/amdgpu/home/fai_qle",
  "runArgs": [
    "--name", "vllm-dev",
    "--workdir", "/shared/amdgpu/home/fai_qle",
    "--entrypoint", "/bin/bash",
    "--ipc=host",
    "--privileged",
    "--cap-add=CAP_SYS_ADMIN",
    "--device=/dev/kfd",
    "--device=/dev/dri",
    "--device=/dev/mem",
    "--group-add", "render",
    "--cap-add=SYS_PTRACE",
    "--security-opt", "seccomp=unconfined",
    "-v", "/sys:/sys:ro",
    "-v", "/data:/data",
    "-v", "/shared/data/amd_int/models:/shared/data/amd_int/models",
    "-v", "/shared/amdgpu/home/fai_qle:/shared/amdgpu/home/fai_qle",
    "-e", "HF_HOME=/shared/data/amd_int/models",
    "-p", "8080:8000"
  ],
  "overrideCommand": true,
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
